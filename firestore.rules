rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function operator() {
      return signedIn() && (
        request.auth.token.role in ['admin', 'operator'] ||
        request.auth.token.email == 'asalada09@gmail.com' ||
        request.auth.token.email_verified == true
      );
    }

    match /events/{eventId}/overlays/{overlayId} {
      allow read: if true;
      allow write: if operator();
    }

    match /events/{eventId}/{collectionId}/{docId} {
      allow read: if true;
      allow write: if operator();
    }
  }
}
